<aside class="w-64 bg-[#1b5c40] text-[#EBFAED] hidden md:flex flex-col shadow-xl transition-all duration-300">
    <div class="p-4 border-b border-[#0A290F] flex flex-row items-center gap-4">
        <div class="flex-1">
            <h2 class="text-xl font-bold tracking-wider">CODATA</h2>
            <p class="text-xs text-[#ADEBB7] mt-1 uppercase">Gestão Pública</p>
        </div>
        <img src="<%= user.avatar || '/images/avatars/admin-avatar.svg' %>" alt="User" class="w-10 h-10 rounded-full border-2 border-green-950 object-cover">
    </div>

    <nav class="flex-1 mt-4 px-4 space-y-2 overflow-y-auto">
        <a href="/admin/dashboard-view" class="flex items-center p-3 rounded-lg hover:bg-[#0F3D17] transition">
            <i class="fas fa-chart-line w-6"></i> Dashboard
        </a>
        <a href="/admin/users-view" class="flex items-center p-3 rounded-lg hover:bg-[#0F3D17] transition">
            <i class="fas fa-users w-6"></i> Usuários
        </a>
        <a href="/admin/monitor-view" class="flex items-center p-3 rounded-lg hover:bg-[#0F3D17] transition">
            <i class="fas fa-server w-6"></i> Monitor API
        </a>
        <a href="/admin/docs" class="flex items-center p-3 rounded-lg hover:bg-[#0F3D17] transition">
            <i class="fas fa-terminal w-6"></i> Integração & Dados
        </a>

        <div>
            <button onclick="toggleMenu('submenu-metodologia')" class="w-full flex items-center justify-between p-3 rounded-lg hover:bg-[#0F3D17] transition focus:outline-none">
                <div class="flex items-center">
                    <i class="fas fa-pen w-6"></i> 
                    <span>Metodologia</span>
                </div>
                <i class="fas fa-chevron-down text-xs transition-transform duration-200" id="arrow-metodologia"></i>
            </button>
            
            <div id="submenu-metodologia" class="hidden pl-8 space-y-1 mt-1">
                <a href="/admin/pages/metodologia/banner_progress" class="block p-2 text-sm text-green-100 hover:text-white hover:bg-green-800 rounded transition">
                    <i class="fas fa-image w-4 mr-1"></i> Banner & Progresso
                </a>
                <a href="/admin/pages/metodologia/cenarios" class="block p-2 text-sm text-green-100 hover:text-white hover:bg-green-800 rounded transition">
                    <i class="fas fa-layer-group w-4 mr-1"></i> Cenários
                </a>
                <a href="/admin/pages/metodologia/impactos" class="block p-2 text-sm text-green-100 hover:text-white hover:bg-green-800 rounded transition">
                    <i class="fas fa-heartbeat w-4 mr-1"></i> Impactos Saúde
                </a>
                <a href="/admin/pages/metodologia/reducoes" class="block p-2 text-sm text-green-100 hover:text-white hover:bg-green-800 rounded transition">
                    <i class="fas fa-leaf w-4 mr-1"></i> Reduções
                </a>
            </div>
        </div>
        </nav>

    <div class="p-4 border-t border-[#0A290F]">
        <a href="/admin/logout" class="flex items-center p-3 text-red-400 hover:bg-red-900/20 rounded-lg transition">
            <i class="fas fa-sign-out-alt w-6"></i> Sair
        </a>
    </div>
</aside>

<script>
    function toggleMenu(menuId) {
        const menu = document.getElementById(menuId);
        const arrow = document.getElementById('arrow-metodologia');
        
        if (menu.classList.contains('hidden')) {
            menu.classList.remove('hidden');
            arrow.style.transform = 'rotate(180deg)';
        } else {
            menu.classList.add('hidden');
            arrow.style.transform = 'rotate(0deg)';
        }
    }
</script>